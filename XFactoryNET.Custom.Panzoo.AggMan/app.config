<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>
        <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="XFactoryNET.Custom.Panzoo.AggMan.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <connectionStrings>
        <add name="XFactoryNET.Custom.Panzoo.AggMan.Properties.Settings.ConnectionString"
            connectionString="Data Source=.\sqlexpress;Initial Catalog=XFactoryNET;Integrated Security=True"
            providerName="System.Data.SqlClient" />
    </connectionStrings>
    <applicationSettings>
        <XFactoryNET.Custom.Panzoo.AggMan.Properties.Settings>
            <setting name="BaudRate" serializeAs="String">
                <value>4800</value>
            </setting>
            <setting name="DataBits" serializeAs="String">
                <value>7</value>
            </setting>
            <setting name="Parity" serializeAs="String">
                <value>Even</value>
            </setting>
            <setting name="PortName" serializeAs="String">
                <value>COM1</value>
            </setting>
            <setting name="StopBits" serializeAs="String">
                <value>Two</value>
            </setting>
        </XFactoryNET.Custom.Panzoo.AggMan.Properties.Settings>
    </applicationSettings>
</configuration>