<?xml version="1.0"?>
<configuration>
  <system.web>
    <compilation debug="true"/>
  </system.web>
<startup>
  <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.1"/>
</startup>
  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="netTcpBinding">
          <security mode="None"/>
        </binding>
      </netTcpBinding>
    </bindings>
    <behaviors>
      <serviceBehaviors>
        <behavior name="">
          <serviceMetadata httpGetEnabled="false"/>
          <serviceDebug includeExceptionDetailInFaults="false"/>
        </behavior>
      </serviceBehaviors>
    </behaviors>
    <services>
      <service name="XFactoryNET.Custom.Panzoo.ServiceLibrary.SvcDosaggio">
        <endpoint address="" binding="netTcpBinding" bindingConfiguration="" contract="XFactoryNET.Custom.Panzoo.ServiceLibrary.ISvcDosaggio">
        </endpoint>
        <endpoint address="mex" binding="mexTcpBinding" bindingConfiguration="" contract="IMetadataExchange"/>
        <host>
          <baseAddresses>
            <add baseAddress="net.tcp://localhost:8523/XFactoryNET/SvcDosaggio"/>
          </baseAddresses>
        </host>
      </service>
    </services>
  </system.serviceModel>
</configuration>
